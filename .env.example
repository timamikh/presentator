# ===========================================
# Presentator MVP — Environment Configuration
# ===========================================
# Copy this file to .env and fill in real values.

# --- PostgreSQL ---
POSTGRES_USER=presentator
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=presentator
POSTGRES_PORT=5432

# --- n8n ---
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=CHANGE_ME
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_PATH=/n8n/
WEBHOOK_URL=http://localhost/n8n/
N8N_DB_TYPE=postgresdb
N8N_DB_POSTGRESDB_HOST=postgres
N8N_DB_POSTGRESDB_PORT=5432
N8N_DB_POSTGRESDB_DATABASE=presentator
N8N_DB_POSTGRESDB_USER=presentator
N8N_DB_POSTGRESDB_PASSWORD=CHANGE_ME
N8N_DB_POSTGRESDB_SCHEMA=n8n

# --- Nginx ---
NGINX_PORT=80

# --- JWT ---
JWT_SECRET=CHANGE_ME_RANDOM_STRING_64_CHARS

# --- LLM (OpenAI-compatible API) ---
LLM_API_KEY=CHANGE_ME
LLM_BASE_URL=http://your-llm-host:port/v1
LLM_MODEL=your-model-name

# --- Internal API key (n8n -> api-service callbacks) ---
INTERNAL_API_KEY=CHANGE_ME_RANDOM_STRING

# --- Seed user ---
SEED_USER_EMAIL=test@presentator.local
SEED_USER_PASSWORD=CHANGE_ME

# --- n8n Webhook ---
N8N_WEBHOOK_URL=http://n8n:5678/webhook/presentator-pipeline
